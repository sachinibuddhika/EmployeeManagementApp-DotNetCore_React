  "components": {
    "schemas": {
      "Department": {
        "required": [
          "createdDate",
          "departmentCode",
          "departmentName",
          "modifiedDate"
        ],
        "type": "object",
        "properties": {
          "departmentId": {
            "type": "integer",
            "format": "int32"
          },
          "departmentCode": {
            "maxLength": 10,
            "minLength": 1,
            "type": "string"
          },
          "departmentName": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time"
          },
          "employees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Employee"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Employee": {
        "required": [
          "age",
          "contactNo",
          "createdDate",
          "dob",
          "email",
          "firstName",
          "lastName",
          "modifiedDate",
          "passwordHash",
          "role",
          "salary"
        ],
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "integer",
            "format": "int32"
          },
          "firstName": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "maxLength": 50,
            "minLength": 1,
            "pattern": "^\\S+@\\S+\\.\\S+$",
            "type": "string"
          },
          "dob": {
            "type": "string",
            "format": "date"
          },
          "age": {
            "type": "integer",
            "format": "int32"
          },
          "salary": {
            "type": "number",
            "format": "double"
          },
          "departmentID": {
            "type": "integer",
            "format": "int32"
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time"
          },
          "passwordHash": {
            "minLength": 1,
            "type": "string"
          },
          "role": {
            "minLength": 1,
            "type": "string"
          },
          "contactNo": {
            "minLength": 1,
            "pattern": "^\\d{10}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter JWT token like: Bearer <your token>",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
